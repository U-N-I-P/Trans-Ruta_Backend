{
  "name": "trans-ruta-backend",
  "version": "1.0.0",
  "description": "Backend del sistema Trans-Ruta — Gestión logística y transporte de carga",
  "main": "server.js",
  "packageManager": "pnpm@11.1.0",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:migrate": "pnpm exec sequelize-cli db:migrate",
    "db:migrate:undo": "pnpm exec sequelize-cli db:migrate:undo:all",
    "db:seed": "pnpm exec sequelize-cli db:seed:all",
    "db:reset": "pnpm run db:migrate:undo && pnpm run db:migrate && pnpm run db:seed"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pdfkit": "^0.15.0",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.0"
  },
  "devDependencies": {
    "bcryptjs": "^3.0.3",
    "nodemon": "^3.0.2",
    "sequelize-cli": "^6.6.2"
  }
}
